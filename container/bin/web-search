#!/usr/bin/env python3
import html
import sys
import urllib.parse
import urllib.request
import xml.etree.ElementTree as ET


def usage() -> int:
    print("Usage: web-search [-n COUNT] QUERY...", file=sys.stderr)
    return 2


def main() -> int:
    args = sys.argv[1:]
    count = 5
    if not args:
        return usage()

    if args[:2] and args[0] == "-n":
        if len(args) < 3:
            return usage()
        try:
            count = max(1, min(10, int(args[1])))
        except ValueError:
            return usage()
        args = args[2:]

    if not args:
        return usage()

    query = " ".join(args)
    params = urllib.parse.urlencode({"format": "rss", "q": query})
    url = f"https://www.bing.com/search?{params}"
    req = urllib.request.Request(
        url,
        headers={
            "User-Agent": "Mozilla/5.0 (NanoClaw web-search)",
            "Accept": "application/rss+xml, application/xml;q=0.9, */*;q=0.8",
        },
    )

    with urllib.request.urlopen(req, timeout=20) as resp:
        payload = resp.read()

    root = ET.fromstring(payload)
    items = root.findall(".//item")

    print(f"Query: {query}")
    if not items:
        print("No results.")
        return 0

    for i, item in enumerate(items[:count], start=1):
        title = html.unescape((item.findtext("title") or "").strip())
        link = (item.findtext("link") or "").strip()
        desc = html.unescape((item.findtext("description") or "").strip())
        print(f"{i}. {title}")
        print(f"   URL: {link}")
        if desc:
            print(f"   Snippet: {desc}")

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
